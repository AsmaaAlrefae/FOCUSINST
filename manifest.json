{
  "manifest_version": 3,
  "name": "FocusInst",
  "description": "Instagram without the noise. Search, don't scroll.",
  "version": "1.0.0",
  "permissions": ["storage"],
  "host_permissions": ["*://www.instagram.com/*"],
  "content_scripts": [
    {
      "matches": ["*://www.instagram.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "FocusInst"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
